<link rel="stylesheet" type="text/css" href="client/custom/modules/estadisticas-mercado/res/css/estilos.css">

<div class="em-page-header">
    <div class="em-header-icon">
        <i class="fas fa-chart-bar"></i>
    </div>
    <div>
        <h2 class="em-page-title">Estadísticas de Mercado</h2>
        <p class="em-page-sub">Seleccione el reporte que desea generar</p>
    </div>
</div>

<div class="em-grid">

    <div class="em-card" data-action="irReporte" data-reporte="ladosPorTipoOperacion">
        <div class="em-card-icon"><i class="fas fa-exchange-alt"></i></div>
        <h4>Lado por Tipo de Operación</h4>
        <p>Conteo de lados agrupados por tipo de operación (Venta / Alquiler) y oficina</p>
    </div>

    <div class="em-card em-card-pronto">
        <div class="em-card-icon"><i class="fas fa-user-tie"></i></div>
        <h4>Tipo de Lados por Asesor</h4>
        <p>Desglose de lados por asesor y tipo de operación</p>
    </div>

    <div class="em-card em-card-pronto">
        <div class="em-card-icon"><i class="fas fa-building"></i></div>
        <h4>Tipo de Lados por Oficina</h4>
        <p>Distribución de tipos de lados por oficina</p>
    </div>

    <div class="em-card em-card-pronto">
        <div class="em-card-icon"><i class="fas fa-ruler-combined"></i></div>
        <h4>Mtr² por CLA</h4>
        <p>Estadísticas de metros cuadrados agrupados por CLA</p>
    </div>

    <div class="em-card em-card-pronto">
        <div class="em-card-icon"><i class="fas fa-tags"></i></div>
        <h4>Rango de Precios</h4>
        <p>Distribución de propiedades por rangos de precio</p>
    </div>

    <div class="em-card em-card-pronto">
        <div class="em-card-icon"><i class="fas fa-chart-area"></i></div>
        <h4>Informe Estadístico por Mtr²</h4>
        <p>Análisis estadístico del mercado basado en metros cuadrados</p>
    </div>

</div>
